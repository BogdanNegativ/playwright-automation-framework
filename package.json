{
  "name": "playwright-automation-framework",
  "version": "1.0.0",
  "description": "Complete Playwright UI automation framework with POM, fixtures, and Allure reporting",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "npm run report:generate && allure open allure-report",
    "install:browsers": "playwright install",
    "clean:reports": "rimraf allure-results allure-report test-results playwright-report"
  },
  "keywords": [
    "playwright",
    "automation",
    "testing",
    "e2e",
    "pom",
    "allure"
  ],
  "author": "QA Automation Engineer",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.8.0",
    "allure-playwright": "^2.5.0",
    "dotenv": "^16.3.1",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
